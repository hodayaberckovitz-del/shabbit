# === Google Sheets ===
# מאימייל ה-Service Account ש-הורדת מ-Google Cloud Console
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service@your-project.iam.gserviceaccount.com

# ה-Private Key מתוך קובץ ה-JSON. להעתיק את כל הערך כולל BEGIN/END
# חשוב: להחליף את \n אמיתיים ב-"\n" בתוך מרכאות
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"

# ה-ID של הגיליון (נמצא ב-URL של Google Sheets)
# לדוגמה: https://docs.google.com/spreadsheets/d/1AbCdEfGhIjKlMnOpQrStUvWxYz/edit
# אז ה-ID הוא 1AbCdEfGhIjKlMnOpQrStUvWxYz
GOOGLE_SHEET_ID=your-sheet-id-here

# === Cloudinary (תמונות) ===
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# === Make.com Webhook (לשלב 3) ===
MAKE_WEBHOOK_URL=https://hook.eu2.make.com/your-webhook-id

# === שרת ===
PORT=3000
NODE_ENV=development
